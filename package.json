{
    "name":  "pcdoctor-workbench",
    "version":  "2.5.12",
    "engines":  {
                    "node":  "\u003e=17.3.0"
                },
    "description":  "Local PC maintenance dashboard + action workbench",
    "author":  "Greg Pajak \u003ciseeuseeingme@gmail.com\u003e",
    "main":  "dist-electron/main/main.cjs",
    "type":  "module",
    "scripts":  {
                    "dev":  "vite",
                    "build":  "vite build \u0026\u0026 node scripts/add-cjs-package-json.mjs",
                    "preview":  "vite preview",
                    "package":  "npm run build && npx @electron/rebuild -f -o better-sqlite3 && electron-builder",
                    "test:smoke":  "powershell.exe -ExecutionPolicy Bypass -File scripts/test-installed-smoke.ps1",
                    "verify:abi":  "powershell.exe -ExecutionPolicy Bypass -File scripts/verify-better-sqlite3-abi.ps1",
                    "typecheck":  "tsc -p tsconfig.main.json --noEmit \u0026\u0026 tsc -p tsconfig.renderer.json --noEmit",
                    "test":  "vitest run",
                    "test:watch":  "vitest",
                    "test:tasks":  "powershell.exe -ExecutionPolicy Bypass -File scripts/test-task-registration.ps1",
                    "test:bundle-sync":  "powershell.exe -ExecutionPolicy Bypass -File scripts/test-bundle-sync-coverage.ps1",
                    "lint":  "eslint src --ext .ts,.tsx"
                },
    "dependencies":  {
                         "adm-zip":  "^0.5.17",
                         "better-sqlite3":  "^11.3.0",
                         "electron-updater":  "^6.8.3",
                         "react":  "^18.3.1",
                         "react-dom":  "^18.3.1",
                         "react-router-dom":  "^6.30.3",
                         "xterm":  "^5.3.0",
                         "xterm-addon-fit":  "^0.8.0"
                     },
    "optionalDependencies":  {
                                 "node-pty":  "^1.1.0"
                             },
    "devDependencies":  {
                            "@electron/rebuild":  "^4.0.3",
                            "@testing-library/jest-dom":  "^6.5.0",
                            "@testing-library/react":  "^16.0.1",
                            "@types/adm-zip":  "^0.5.8",
                            "@types/better-sqlite3":  "^7.6.11",
                            "@types/node":  "^22.7.4",
                            "@types/react":  "^18.3.11",
                            "@types/react-dom":  "^18.3.0",
                            "@vitejs/plugin-react":  "^4.3.2",
                            "autoprefixer":  "^10.4.20",
                            "electron":  "^33.0.0",
                            "electron-builder":  "^25.1.8",
                            "electron-log":  "^5.2.0",
                            "eslint":  "^9.12.0",
                            "jsdom":  "^25.0.1",
                            "postcss":  "^8.4.47",
                            "tailwindcss":  "^3.4.13",
                            "typescript":  "^5.6.2",
                            "vite":  "^5.4.8",
                            "vite-plugin-electron":  "^0.28.8",
                            "vite-plugin-electron-renderer":  "^0.14.6",
                            "vitest":  "^2.1.2"
                        }
}